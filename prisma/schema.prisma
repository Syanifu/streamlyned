generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                   @id @default(uuid())
  email              String                   @unique
  name               String
  avatarUrl          String?
  coverUrl           String?
  planTier           String                   @default("standard")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  passwordHash       String?
  auditLogs          AuditLog[]
  calendarAttendees  CalendarEventAttendee[]
  chatMessages       ChatMessage[]
  chatReactions      ChatMessageReaction[]
  checkInAnswers     CheckInAnswer[]
  comments           Comment[]
  discussions        Discussion[]
  discussionSubs     DiscussionSubscription[]
  dmMemberships      DmGroupMember[]
  notifications      Notification[]
  projectMemberships ProjectMember[]
  projectFiles       ProjectFile[]
  knowledgeUploads   WorkspaceKnowledge[]
  taskAssignees      TaskAssignee[]
  memberships        WorkspaceMember[]
  aiConfigs          AiConfig[]
  googleCalendarToken GoogleCalendarToken?
  sessions           Session[]
  connections        Connection[]
}

model Workspace {
  id               String               @id @default(uuid())
  name             String
  slug             String               @unique
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  apiKey           String?              @unique
  aiSettings       AiSettings?
  auditLogs        AuditLog[]
  events           CalendarEvent[]
  chatMessages     ChatMessage[]
  checkInQuestions CheckInQuestion[]
  comments         Comment[]
  discussions      Discussion[]
  dmGroups         DmGroup[]
  docs             Doc[]
  embeddings       Embedding[]
  notifications    Notification[]
  projects         Project[]
  members          WorkspaceMember[]
  knowledgeFiles   WorkspaceKnowledge[]
  aiConfig         AiConfig?
  notionConnection NotionConnection?
  sessions         Session[]
  connections      Connection[]
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  role        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Project {
  id               String            @id @default(uuid())
  workspaceId      String
  name             String
  description      String?
  isArchived       Boolean           @default(false)
  archivedAt       DateTime?
  deletedAt        DateTime?
  tools            String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  startDate      DateTime?
  endDate        DateTime?
  agenticEnabled Boolean           @default(true) @map("agentic_enabled")
  auditLogs      AuditLog[]
  events           CalendarEvent[]
  chatMessages     ChatMessage[]
  checkInQuestions CheckInQuestion[]
  discussions      Discussion[]
  docs             Doc[]
  files            ProjectFile[]
  hillChartItems   HillChartItem[]
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members          ProjectMember[]
  taskLists        TaskList[]
}

model ProjectMember {
  id           String   @id @default(uuid())
  projectId    String
  userId       String
  visibleTools String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model TaskList {
  id        String  @id @default(uuid())
  projectId String
  name      String
  position  Float
  tasks     Task[]
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id               String           @id @default(uuid())
  workspaceId      String
  taskListId       String
  projectId        String
  title            String
  notes            String?
  dueDateStart     DateTime?
  dueDateEnd       DateTime?
  recurrence       String?
  position         Float
  isCompleted      Boolean          @default(false)
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  visibleToClients Boolean          @default(true)
  priority         String           @default("P4")
  comments         Comment[]
  taskList         TaskList         @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  assignees        TaskAssignee[]
  attachments      TaskAttachment[]
}

model TaskAssignee {
  id     String @id @default(uuid())
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskAttachment {
  id        String   @id @default(uuid())
  taskId    String
  fileName  String
  fileUrl   String
  fileSize  Int
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ProjectFile {
  id           String   @id @default(uuid())
  workspaceId  String
  projectId    String
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  uploadedById String
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

model Comment {
  id              String      @id @default(uuid())
  workspaceId     String
  taskId          String?
  discussionId    String?
  docId           String?
  userId          String
  content         String
  isClientComment Boolean     @default(false)
  createdAt       DateTime    @default(now())
  discussion      Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  doc             Doc?        @relation(fields: [docId], references: [id], onDelete: Cascade)
  task            Task?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Discussion {
  id               String                   @id @default(uuid())
  workspaceId      String
  projectId        String
  title            String
  content          String
  userId           String
  isPinned         Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  visibleToClients Boolean                  @default(true)
  comments         Comment[]
  project          Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subs             DiscussionSubscription[]
}

model DiscussionSubscription {
  id           String     @id @default(uuid())
  discussionId String
  userId       String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
}

model ChatMessage {
  id          String                @id @default(uuid())
  workspaceId String
  projectId   String?
  dmGroupId   String?
  userId      String
  content     String
  createdAt   DateTime              @default(now())
  dmGroup     DmGroup?              @relation(fields: [dmGroupId], references: [id], onDelete: Cascade)
  project     Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  files       ChatMessageFile[]
  reactions   ChatMessageReaction[]
}

model ChatMessageReaction {
  id        String      @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model ChatMessageFile {
  id        String      @id @default(uuid())
  messageId String
  fileName  String
  fileUrl   String
  fileSize  Int
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model DmGroup {
  id          String          @id @default(uuid())
  workspaceId String
  name        String?
  createdAt   DateTime        @default(now())
  messages    ChatMessage[]
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     DmGroupMember[]
}

model DmGroupMember {
  id        String  @id @default(uuid())
  dmGroupId String
  userId    String
  dmGroup   DmGroup @relation(fields: [dmGroupId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dmGroupId, userId])
}

model Doc {
  id               String       @id @default(uuid())
  workspaceId      String
  projectId        String
  title            String
  content          String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  visibleToClients Boolean      @default(true)
  comments         Comment[]
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions         DocVersion[]
}

model DocVersion {
  id          String   @id @default(uuid())
  docId       String
  title       String
  content     String
  version     Int
  createdAt   DateTime @default(now())
  createdById String
  doc         Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id               String                  @id @default(uuid())
  workspaceId      String
  projectId        String
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime
  recurrence       String?
  videoCallLink    String?
  location         String?
  createdAt        DateTime                @default(now())
  priority         String                  @default("P4")
  source           String                  @default("manual")
  sourceRef        String?                 @map("source_ref") @db.Uuid
  progressPct      Int?                    @map("progress_pct")
  agentConfidence  String?                 @map("agent_confidence")
  project          Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace        Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attendees        CalendarEventAttendee[]
}

model CalendarEventAttendee {
  id      String        @id @default(uuid())
  eventId String
  userId  String
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Notification {
  id           String    @id @default(uuid())
  workspaceId  String
  userId       String
  type         String
  title        String
  message      String
  targetUrl    String
  isRead       Boolean   @default(false)
  isSuppressed Boolean   @default(false)
  createdAt    DateTime  @default(now())
  priority     String    @default("P4")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String?
  entityType  String
  entityId    String
  userId      String
  action      String
  description String
  createdAt   DateTime  @default(now())
  priority    String    @default("P4")
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Embedding {
  id          String    @id @default(uuid())
  workspaceId String
  entityType  String
  entityId    String
  projectId   String?
  text        String
  vector      String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AiSettings {
  id              String    @id @default(uuid())
  workspaceId     String    @unique
  provider        String    @default("openai")
  apiKey          String?
  embeddingsModel String    @default("text-embedding-3-small")
  completionModel String    @default("gpt-4o-mini")
  config          String    @default("{}")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CheckInQuestion {
  id           String          @id @default(uuid())
  workspaceId  String
  projectId    String
  question     String
  scheduleDay  String
  scheduleTime String
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  answers      CheckInAnswer[]
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CheckInAnswer {
  id         String          @id @default(uuid())
  questionId String
  userId     String
  content    String
  createdAt  DateTime        @default(now())
  question   CheckInQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HillChartItem {
  id        String   @id @default(uuid())
  projectId String
  name      String
  progress  Float    @default(50.0)
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AiConfig {
  id           String    @id @default(uuid())
  orgId        String    @unique @map("org_id")
  systemPrompt String    @map("system_prompt")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy    String    @map("updated_by")
  workspace    Workspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [updatedBy], references: [id], onDelete: Cascade)

  @@map("ai_config")
}

model GoogleCalendarToken {
  id            String    @id @default(uuid())
  userId        String    @unique
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime?
  syncedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceKnowledge {
  id           String    @id @default(uuid())
  workspaceId  String
  name         String
  description  String?
  fileUrl      String
  fileSize     Int
  mimeType     String
  textContent  String?
  uploadedById String
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
}

model NotionConnection {
  id            String    @id @default(uuid())
  workspaceId   String    @unique
  accessToken   String
  botId         String
  notionWorkspaceName String?
  notionWorkspaceIcon String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// --- Phase 0: Secure session model ---
model Session {
  id            String    @id @default(uuid())
  userId        String
  workspaceId   String
  tokenHash     String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime  @default(now())
  ipHash        String?
  userAgentHash String?
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// --- Phase 1: Unified integration connection model ---
model Connection {
  id                  String         @id @default(uuid())
  provider            String
  ownerType           String         // USER | WORKSPACE
  userId              String?
  workspaceId         String?
  externalAccountId   String?
  externalAccountName String?
  accessToken         String         // encrypted (AES-256-GCM)
  refreshToken        String?        // encrypted
  tokenType           String?
  tokenSecret         String?        // encrypted, oauth1
  scopes              String         @default("[]") // JSON array
  expiresAt           DateTime?
  status              String         @default("active") // active|expired|revoked|error
  lastSyncedAt        DateTime?
  lastError           String?
  metadata            String?        // JSON
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  externalItems       ExternalItem[]
}

// --- Phase 1: Dedup tracking for imported external content ---
model ExternalItem {
  id              String     @id @default(uuid())
  connectionId    String
  provider        String
  externalId      String
  externalType    String     // page|database|record|file|doc|note
  localEntityType String     // DOC|PROJECT|TASK|FILE|EMBEDDING
  localEntityId   String
  contentHash     String?
  syncDirection   String     @default("inbound")
  lastSyncedAt    DateTime   @default(now())
  connection      Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalId])
}

// --- Cross-cutting: Append-only audit trail ---
model AuditEvent {
  id           String   @id @default(uuid())
  actorUserId  String?
  workspaceId  String?
  action       String
  resourceType String?
  resourceId   String?
  ipHash       String?
  metadata     String?  // JSON
  createdAt    DateTime @default(now())
}
